source "https://rubygems.org"

gem "jekyll", "~> 4.3"
gem "jekyll-text-theme", "~> 2.2"

# TeXt runtime plugins
gem "jekyll-sitemap"

# Windows / JRuby timezone + file-watch support
platforms :mingw, :x64_mingw, :mswin, :jruby do
  gem "tzinfo", ">= 1", "< 3"
  gem "tzinfo-data"
  gem "wdm", "~> 0.1.1"
end
